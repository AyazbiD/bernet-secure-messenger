# Bernet Messenger — Environment Variables
# Copy this file to .env and fill in the values

# JWT Secret Key (replace with a random 256-bit key in production)
JWT_SECRET=change-this-secret-key-in-production

# Admin account password (used on first launch to create admin user)
ADMIN_PASSWORD=admin

# Server settings
HOST=0.0.0.0
PORT=8000

# Note about E2E encryption: 
# On a fresh database, 2 demo accounts are created:
# - admin (pass: admin) 
# - test (pass: test)
#
# To test messaging, you MUST log in to BOTH accounts at least once. 
# This generates their RSA keys. Without keys, you can't send messages!
